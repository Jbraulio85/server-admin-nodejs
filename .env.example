# Copia a .env: cp .env.example .env
#
# Puertos:
#   Local (pnpm dev): 3002
#   Docker Compose:   3009

# Server Configuration
PORT=3002

# MongoDB (compartida con server-user)
# Local standalone: mongodb://localhost:27017/kinalSports
# Stack Docker desde el host: mongodb://localhost:27020/kinalSports
URI_MONGODB=mongodb://localhost:27017/kinalSports

# CORS - origenes permitidos (separados por coma)
ADMIN_ALLOWED_ORIGINS=http://localhost:5173

# JWT (debe coincidir con auth-service)
JWT_SECRET=change-me-jwt-secret-min-256-bits
JWT_ISSUER=AuthService
JWT_AUDIENCE=AuthService

# Integracion con auth-service
AUTH_SERVICE_URL=http://localhost:5156/api/v1

# Token interno para comunicacion con server-user
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token

# Cloudinary - campos deportivos
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_BASE_URL=https://res.cloudinary.com/your-cloud-name/image/upload/
CLOUDINARY_FOLDER=admin_service/fields
CLOUDINARY_DEFAULT_FIELD_FILENAME=default-field.png
CLOUDINARY_DEFAULT_FIELD=admin_service/fields/default-field.png

# Cloudinary - equipos y torneos
CLOUDINARY_TEAMS_FOLDER=kinal_sports/teams
CLOUDINARY_TOURNAMENTS_FOLDER=kinal_sports/tournaments
